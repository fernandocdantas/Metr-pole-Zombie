# =============================================================================
# Project Zomboid Server — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Lines marked [REQUIRED] must be set before first run.
# =============================================================================

# -----------------------------------------------------------------------------
# Game Server
# -----------------------------------------------------------------------------
PZ_SERVER_NAME=ZomboidServer
PZ_ADMIN_USERNAME=admin
PZ_ADMIN_PASSWORD=                          # [REQUIRED] Admin password for in-game admin
PZ_SERVER_PASSWORD=                         # Leave empty for no password
PZ_MAX_PLAYERS=16
PZ_MAX_RAM=4096m
PZ_GAME_PORT=16261
PZ_DIRECT_PORT=16262
PZ_RCON_PORT=27015
PZ_RCON_PASSWORD=                           # [REQUIRED] RCON password for API communication
PZ_STEAM_BRANCH=public                      # "public" for stable, "unstable" for B42 beta
PZ_MAP_NAMES=Muldraugh, KY
PZ_MOD_IDS=                                 # Semicolon-separated mod IDs
PZ_WORKSHOP_IDS=                            # Semicolon-separated Workshop item IDs
PZ_PAUSE_ON_EMPTY=true
PZ_PUBLIC_SERVER=true
PZ_STEAM_VAC=true
PZ_AUTOSAVE_INTERVAL=15
PZ_GC_CONFIG=ZGC                            # Java GC: ZGC, G1GC, ShenandoahGC
TZ=Asia/Tbilisi

# -----------------------------------------------------------------------------
# Laravel Application
# -----------------------------------------------------------------------------
APP_NAME="PZ Server Manager"
APP_ENV=production
APP_KEY=                                    # Run: php artisan key:generate
APP_DEBUG=false
APP_URL=http://localhost:8000
APP_PORT=8000

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=zomboid
DB_USERNAME=zomboid
DB_PASSWORD=                                # [REQUIRED] PostgreSQL password

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# -----------------------------------------------------------------------------
# API Authentication
# -----------------------------------------------------------------------------
API_KEY=                                    # [REQUIRED] API key for admin endpoints

# -----------------------------------------------------------------------------
# Docker Control
# -----------------------------------------------------------------------------
GAME_SERVER_CONTAINER_NAME=pz-game-server

# -----------------------------------------------------------------------------
# Queue & Cache
# -----------------------------------------------------------------------------
QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis

# -----------------------------------------------------------------------------
# Paths (inside app container)
# -----------------------------------------------------------------------------
PZ_DATA_PATH=/pz-data
